# Copy to `.env.local` and fill in. Never commit `.env.local`.

# If set, the app uses OpenAI for AI tools (vision gpt-4o, images gpt-image-1, TTS, agent).
OPENAI_API_KEY=

# Model pentru images.edit (implicit în cod: gpt-image-2). Poți pune gpt-image-1 dacă API-ul refuză.
OPENAI_IMAGE_MODEL=

# Calitate imagine OpenAI: high | medium | low | auto
OPENAI_IMAGE_QUALITY=

# Max. apeluri images.edit per acțiune (prima generare + regenerări după QA). 1–5, implicit 3.
OPENAI_IMAGE_MAX_PASSES=

# După fiecare imagine: gpt-4o compară OUTPUT vs REFERENCE; dacă găsește defecte clare, urmează regenerare. Dezactivează: 0 sau false
OPENAI_IMAGE_CRITIQUE=

# If OpenAI is empty, Google Gemini is used when this is set:
GEMINI_API_KEY=

# Optional alias for Gemini (some templates use API_KEY).
API_KEY=

# APP_URL: Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
