# Copy to `.env.local` and fill in. Never commit `.env.local`.

# Model Gemini pentru imagini (mockup, upscale, bleed AI). Lasă gol = Nano Banana Pro (gemini-3-pro-image-preview).
# Dacă primești 404/403: GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview (Nano Banana 2) sau gemini-2.5-flash-image
# Opțional — preferă Setări AI din app; acestea suprascriu doar dacă nu ai salvat în UI.
GEMINI_IMAGE_MODEL=
GEMINI_TEXT_MODEL=

# If set, the app uses OpenAI for AI tools (vision gpt-4o, images gpt-image-1, TTS, agent).
OPENAI_API_KEY=

OPENAI_IMAGE_MODEL=
OPENAI_AGENT_MODEL=
OPENAI_VISION_MODEL=

# Calitate imagine OpenAI: high | medium | low | auto
OPENAI_IMAGE_QUALITY=

# Max. apeluri images.edit per acțiune (prima generare + regenerări după QA). 1–5, implicit 3.
OPENAI_IMAGE_MAX_PASSES=

# După fiecare imagine: gpt-4o compară OUTPUT vs REFERENCE; dacă găsește defecte clare, urmează regenerare. Dezactivează: 0 sau false
OPENAI_IMAGE_CRITIQUE=

# If OpenAI is empty, Google Gemini is used when this is set:
GEMINI_API_KEY=

# Optional alias for Gemini (some templates use API_KEY).
API_KEY=

# APP_URL: Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Supabase — istoric fișiere grupate + storage (Firebase Auth ca third-party în dashboard)
VITE_SUPABASE_URL=https://gmjmtctxnmgpddfdaecr.supabase.co
# Prefer anon (JWT) for Firebase third-party auth; publishable key is fallback
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
