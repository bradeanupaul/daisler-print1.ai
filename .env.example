# Copy to `.env.local` and fill in. Never commit `.env.local`.
#
# Local: `.env.local` · Vercel: Project → Settings → Environment Variables
# (același nume: GEMINI_API_KEY, OPENAI_API_KEY). După modificare pe Vercel → Redeploy.
# Nu e nevoie de prefix VITE_ pentru cheile AI — sunt injectate la build.

# Model imagini Gemini: imagen-4.0-fast-generate-001 (ieftin) | imagen-4.0-generate-001 | gemini-2.5-flash-image | gemini-3-pro-image-preview
# Imagen = generateImages (prompt). Nano Banana = edit pe imagine sursă.
# Opțional — preferă Setări AI din app; acestea suprascriu doar dacă nu ai salvat în UI.
GEMINI_IMAGE_MODEL=
GEMINI_TEXT_MODEL=

# If set, the app uses OpenAI for AI tools (vision gpt-4o, images gpt-image-1, TTS, agent).
OPENAI_API_KEY=

# gpt-image-2 | dall-e-2 | dall-e-3 | gpt-image-1 — sau Setări AI din app
OPENAI_IMAGE_MODEL=
OPENAI_AGENT_MODEL=
OPENAI_VISION_MODEL=

# Calitate imagine OpenAI: high | medium | low | auto
OPENAI_IMAGE_QUALITY=

# Max. pași per generare imagine (OpenAI + Gemini): prima + regenerări după QA. 1–5, implicit 3.
OPENAI_IMAGE_MAX_PASSES=

# QA vision: compară ORIGINAL vs OUTPUT; regenerare dacă nu respectă promptul. Dezactivează: 0 sau false
OPENAI_IMAGE_CRITIQUE=

# Prompt upscale: short | premium (implicit premium — structură TASK + ALLOWED + CONSTRAINTS)
AI_UPSCALE_PROMPT_TIER=

# If OpenAI is empty, Google Gemini is used when this is set:
GEMINI_API_KEY=

# Optional alias for Gemini (some templates use API_KEY).
API_KEY=

# APP_URL: Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Supabase — istoric fișiere grupate + storage (Firebase Auth ca third-party în dashboard)
VITE_SUPABASE_URL=https://gmjmtctxnmgpddfdaecr.supabase.co
# Prefer anon (JWT) for Firebase third-party auth; publishable key is fallback
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
